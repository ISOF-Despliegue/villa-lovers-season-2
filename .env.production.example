# StreamButed production environment template.
# Copy to .env.production on the Droplet. Never commit the real file.
# Generate new production secrets; do not reuse local/dev secrets.

# Public domains
FRONTEND_URL=https://migueleelg0106.me
API_URL=https://api.migueleelg0106.me
CORS_ALLOWED_ORIGINS=https://migueleelg0106.me,https://www.migueleelg0106.me

# Frontend build variables for GitHub Pages
VITE_API_BASE_URL=https://api.migueleelg0106.me/api
VITE_GATEWAY_URL=https://api.migueleelg0106.me

# Runtime profile/security
SPRING_PROFILES_ACTIVE=prod
DB_DDL_AUTO=validate
REFRESH_COOKIE_SECURE=true
JWT_ISSUER=https://api.migueleelg0106.me
JWT_AUDIENCE=streambuted-api
JWT_JWKS_URL=http://identity-service:8081/api/v1/auth/.well-known/jwks.json
JWT_KEY_ID=CHANGE_ME_PRODUCTION_KEY_ID
JWT_RSA_PRIVATE_KEY_BASE64=CHANGE_ME_BASE64_PKCS8_PRIVATE_KEY
JWT_RSA_PUBLIC_KEY_BASE64=CHANGE_ME_BASE64_X509_PUBLIC_KEY
JWT_RSA_PRIVATE_KEY_PEM=
JWT_RSA_PUBLIC_KEY_PEM=

# PostgreSQL admin/bootstrap user. Runtime services must not use this user.
POSTGRES_USER=streambuted_admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_ADMIN_PASSWORD
POSTGRES_IDENTITY_DB=streambuted_identity
POSTGRES_CATALOG_DB=streambuted_catalog

# PostgreSQL runtime users
POSTGRES_IDENTITY_APP_USER=streambuted_identity_app
POSTGRES_IDENTITY_APP_PASSWORD=CHANGE_ME_IDENTITY_RUNTIME_PASSWORD
POSTGRES_CATALOG_APP_USER=streambuted_catalog_app
POSTGRES_CATALOG_APP_PASSWORD=CHANGE_ME_CATALOG_RUNTIME_PASSWORD

# PostgreSQL migrator users for manual/CI migration steps
POSTGRES_IDENTITY_MIGRATOR_USER=streambuted_identity_migrator
POSTGRES_IDENTITY_MIGRATOR_PASSWORD=CHANGE_ME_IDENTITY_MIGRATOR_PASSWORD
POSTGRES_CATALOG_MIGRATOR_USER=streambuted_catalog_migrator
POSTGRES_CATALOG_MIGRATOR_PASSWORD=CHANGE_ME_CATALOG_MIGRATOR_PASSWORD
CATALOG_MIGRATOR_DATABASE_URL=postgresql://streambuted_catalog_migrator:CHANGE_ME_CATALOG_MIGRATOR_PASSWORD@catalog-postgres:5432/streambuted_catalog?schema=public

# MongoDB for Streaming
STREAMING_MONGO_DB=streambuted_streaming
STREAMING_MONGO_ROOT_USER=streambuted_mongo_admin
STREAMING_MONGO_ROOT_PASSWORD=CHANGE_ME_MONGO_ROOT_PASSWORD
STREAMING_MONGO_APP_USER=streambuted_streaming_app
STREAMING_MONGO_APP_PASSWORD=CHANGE_ME_STREAMING_MONGO_APP_PASSWORD
STREAMING_MONGO_URI=mongodb://streambuted_streaming_app:CHANGE_ME_STREAMING_MONGO_APP_PASSWORD@streaming-mongo:27017/streambuted_streaming?authSource=streambuted_streaming

# RabbitMQ
RABBITMQ_DEFAULT_USER=streambuted_rabbitmq
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD

# MinIO. Keep API and console unexposed; Media/Streaming serve objects through
# backend endpoints instead of returning public MinIO URLs.
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=internal-only
MINIO_ACCESS_KEY=streambuted_minio
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=streambuted-media
MINIO_SECURE=false

# Application signing/playback secrets
EVENT_SIGNING_SECRET=CHANGE_ME_RANDOM_64_BYTES_BASE64URL
STREAMING_PLAYBACK_TOKEN_SECRET=CHANGE_ME_RANDOM_64_BYTES_BASE64URL
STREAMING_PLAYBACK_TOKEN_TTL_SECONDS=300
STREAMING_VALID_PLAYBACK_SECONDS=30

# Google OAuth. Set real values only in .env.production on the Droplet.
GOOGLE_CLIENT_ID=CHANGE_ME_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=CHANGE_ME_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://api.migueleelg0106.me/api/v1/auth/oauth/google/callback

# SMTP/email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=CHANGE_ME_SMTP_USER
EMAIL_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM="StreamButed <no-reply@migueleelg0106.me>"
EMAIL_SECURE=false
EMAIL_SMTP_AUTH=true
EMAIL_STARTTLS_ENABLE=true
EMAIL_VERIFICATION_SUBJECT=StreamButed verification code
MAIL_HEALTH_ENABLED=false
REGISTRATION_VERIFICATION_CODE_TTL=15m

# Service sizing and internal ports
GATEWAY_INTERNAL_PORT=8080
MEDIA_GRPC_TIMEOUT_MS=2000
MEDIA_MAX_AUDIO_SIZE_MB=200
MEDIA_MAX_IMAGE_SIZE_MB=5
CATALOG_GRPC_TIMEOUT_SECONDS=5
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=CHANGE_ME_DROPLET_PUBLIC_IP
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100
# Initial production deploy keeps direct mediasoup RTP private. To enable Live
# media, deploy TURN/TURNS on 443 or approve/publish a narrow UDP range.
