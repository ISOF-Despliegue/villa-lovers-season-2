{
  "name": "front-streambuted",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:renderer": "vite build",
    "build:pages": "npm run typecheck && npm run build:renderer && node -e \"const fs=require('fs');fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "build:electron": "tsc -p electron/tsconfig.json && node -e \"require('fs').copyFileSync('electron/package.json','dist-electron/package.json')\"",
    "build": "npm run typecheck && npm run build:renderer && npm run build:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "npm run build:electron && node scripts/run-electron.cjs dist-electron/main.js",
    "electron:dev": "concurrently -k \"npm run dev -- --strictPort\" \"npm run electron:dev:wait\"",
    "electron:dev:wait": "wait-on http://localhost:5173 && npm run build:electron && node scripts/run-electron.cjs dist-electron/main.js --dev",
    "test": "jest"
  },
  "dependencies": {
    "mediasoup-client": "^3.20.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-jest": "^30.3.0",
    "concurrently": "^9.2.1",
    "electron": "^42.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  }
}
