 "event": [
  {
   "listen": "prerequest",
   "script": {
    "type": "text/javascript",
    "exec": [
     "const now = Date.now();",
     "if (!pm.collectionVariables.get('runSuffix')) {",
     "  pm.collectionVariables.set('runSuffix', String(now));",
     "}",
     "if (!pm.collectionVariables.get('testEmail')) {",
     "  pm.collectionVariables.set('testEmail', `postman+${now}@example.com`);",
     "}",
     "if (!pm.collectionVariables.get('testUsername')) {",
     "  pm.collectionVariables.set('testUsername', `postman${now}`);",
     "}",
     "if (!pm.collectionVariables.get('testPassword')) {",
     "  pm.collectionVariables.set('testPassword', 'Passw0rd!23');",
     "}",
     "if (!pm.collectionVariables.get('coverAssetId')) {",
     "  pm.collectionVariables.set('coverAssetId', '11111111-1111-4111-8111-111111111111');",
     "}",
     "if (!pm.collectionVariables.get('audioAssetId')) {",
     "  pm.collectionVariables.set('audioAssetId', '22222222-2222-4222-8222-222222222222');",
     "}",
     "if (!pm.collectionVariables.get('trackCoverAssetId')) {",
     "  pm.collectionVariables.set('trackCoverAssetId', '33333333-3333-4333-8333-333333333333');",
     "}",
     "if (!pm.collectionVariables.get('albumTitle')) {",
     "  pm.collectionVariables.set('albumTitle', `Album ${now}`);",
     "}",
     "if (!pm.collectionVariables.get('trackTitle')) {",
     "  pm.collectionVariables.set('trackTitle', `Track ${now}`);",
     "}"
    ]
   }
  }
