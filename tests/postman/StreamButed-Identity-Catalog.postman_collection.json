  {
   "name": "2. Cross-Service Sync (Identity -> Catalog)",
   "item": [
    {
     "name": "Catalog - Get Promoted Artist",
     "request": {
      "method": "GET",
      "header": [],
      "url": {
       "raw": "{{catalogBaseUrl}}/artists/{{userId}}",
       "host": [
        "{{catalogBaseUrl}}"
       ],
       "path": [
        "artists",
        "{{userId}}"
       ]
      }
     },
     "event": [
      {
       "listen": "prerequest",
       "script": {
        "type": "text/javascript",
        "exec": []
       }
      },
      {
       "listen": "test",
       "script": {
        "type": "text/javascript",
        "exec": [
         "const retryKey = 'catalogArtistReplicationRetryCount';",
         "const maxRetries = 5;",
         "const currentRetry = Number(pm.collectionVariables.get(retryKey) || 0);",
         "if (pm.response.code !== 200) {",
         "  if (currentRetry < maxRetries) {",
         "    pm.collectionVariables.set(retryKey, String(currentRetry + 1));",
         "    postman.setNextRequest('Catalog - Get Promoted Artist');",
         "  } else {",
         "    pm.collectionVariables.unset(retryKey);",
         "    pm.test('status 200 (artist replicated from identity event)', function () {",
         "      pm.expect(pm.response.code, `artist was not replicated to catalog within ${maxRetries} retries`).to.eql(200);",
         "    });",
         "  }",
         "} else {",
         "  pm.collectionVariables.unset(retryKey);",
         "  pm.test('status 200 (artist replicated from identity event)', function () { pm.response.to.have.status(200); });",
         "  const json = pm.response.json();",
         "  pm.collectionVariables.set('artistId', json.artistId);",
         "  pm.test('artist id equals promoted user id', function () { pm.expect(json.artistId).to.eql(pm.collectionVariables.get('userId')); });",
         "  pm.test('display name exists', function () { pm.expect(json.displayName).to.be.a('string').and.not.empty; });",
         "}"
        ]
       }
      }
     ]
    }
   ]
  },
