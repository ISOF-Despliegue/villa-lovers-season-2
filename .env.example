# StreamButed - Unified environment template (root)
# Copy this file to .env in the repository root and fill in your values.

POSTGRES_USER=streambuted
POSTGRES_PASSWORD=replace_with_your_db_password
POSTGRES_IDENTITY_DB=streambuted_identity
POSTGRES_CATALOG_DB=streambuted_catalog
POSTGRES_IDENTITY_APP_USER=streambuted_identity_app
POSTGRES_IDENTITY_APP_PASSWORD=replace_with_identity_app_db_password
POSTGRES_CATALOG_APP_USER=streambuted_catalog_app
POSTGRES_CATALOG_APP_PASSWORD=replace_with_catalog_app_db_password
POSTGRES_IDENTITY_PORT=5433
POSTGRES_CATALOG_PORT=5434

RABBITMQ_DEFAULT_USER=streambuted
RABBITMQ_DEFAULT_PASS=replace_with_your_rabbitmq_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=streambuted
MINIO_SECRET_KEY=replace_with_your_minio_secret
MINIO_BUCKET=streambuted-media
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# JWT (asymmetric)
# Identity signs access tokens with RS256 and publishes public keys via JWKS.
# If RSA keys are not configured, identity-service generates an ephemeral key pair at startup (dev only).
JWT_ISSUER=http://identity-service:8081
JWT_KEY_ID=
JWT_RSA_PRIVATE_KEY_PEM=
JWT_RSA_PUBLIC_KEY_PEM=
JWT_RSA_PRIVATE_KEY_BASE64=
JWT_RSA_PUBLIC_KEY_BASE64=

# Catalog and Media validate access tokens locally using the JWKS endpoint.
JWT_JWKS_URL=http://identity-service:8081/api/v1/auth/.well-known/jwks.json
JWT_AUDIENCE=streambuted-api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
FRONTEND_URL=http://localhost:5173/auth/callback
VITE_API_BASE_URL=http://localhost
VITE_GATEWAY_URL=http://localhost
SPRING_PROFILES_ACTIVE=prod
DB_DDL_AUTO=validate
REFRESH_COOKIE_SECURE=true

EVENT_SIGNING_SECRET=CHANGE_ME_SECRET_64_CHARS

# Identity email verification
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace_with_smtp_user
EMAIL_PASSWORD=replace_with_smtp_password
EMAIL_FROM="no-reply-streambuted <no-reply@example.com>"
EMAIL_SECURE=false
EMAIL_SMTP_AUTH=true
EMAIL_STARTTLS_ENABLE=true
EMAIL_CONNECTION_TIMEOUT_MS=5000
EMAIL_READ_TIMEOUT_MS=5000
EMAIL_WRITE_TIMEOUT_MS=5000
EMAIL_VERIFICATION_SUBJECT=StreamButed verification code
MAIL_HEALTH_ENABLED=false
REGISTRATION_VERIFICATION_CODE_TTL=15m

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/oauth/google/callback

IDENTITY_HTTP_PORT=8081
IDENTITY_GRPC_PORT=9091
CATALOG_PORT=8082
CATALOG_GRPC_PORT=9092
MEDIA_PORT=8083
MEDIA_GRPC_PORT=9093
MEDIA_GRPC_TARGET=media-service:9093
MEDIA_GRPC_TIMEOUT_MS=2000
CATALOG_GRPC_TARGET=catalog-service:9092
CATALOG_GRPC_TIMEOUT_SECONDS=5
STREAMING_PORT=8084
STREAMING_MONGO_URI=mongodb://streaming-mongo:27017
STREAMING_MONGO_DB=streambuted_streaming
STREAMING_PLAYBACK_TOKEN_SECRET=replace_with_your_streaming_playback_secret
STREAMING_PLAYBACK_TOKEN_TTL_SECONDS=300
STREAMING_VALID_PLAYBACK_SECONDS=30

MEDIA_MAX_AUDIO_SIZE_MB=200
MEDIA_MAX_IMAGE_SIZE_MB=5

LIVE_PORT=3003
RTC_MIN_PORT=10000
RTC_MAX_PORT=10100
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
