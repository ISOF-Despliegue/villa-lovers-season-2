# StreamButed - Unified environment template (root)
# Copy this file to .env in the repository root and replace CHANGE_ME values.

POSTGRES_USER=streambuted
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=streambuted_identity
POSTGRES_PORT=5432

RABBITMQ_DEFAULT_USER=streambuted
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# HS512 requires a strong secret with at least 64 characters.
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS_FOR_HS512

IDENTITY_HTTP_PORT=8081
IDENTITY_GRPC_PORT=9091
CATALOG_PORT=8082